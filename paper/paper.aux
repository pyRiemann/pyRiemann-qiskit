\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Three-dimensional PCA projection of SPD covariance matrices on synthetic cross-subject EEG before and after Riemannian Procrustes Analysis (RPA). \emph  {Left}: points coloured by subject---RPA collapses each subject's cluster into a shared region, removing between-subject variability. \emph  {Right}: points coloured by class---after alignment, the two mental-state classes become linearly separable in the projected space.}}{7}{figure.7}\protected@file@percent }
\newlabel{fig:ablation_tl}{{7}{7}{Three-dimensional PCA projection of SPD covariance matrices on synthetic cross-subject EEG before and after Riemannian Procrustes Analysis (RPA). \emph {Left}: points coloured by subject---RPA collapses each subject's cluster into a shared region, removing between-subject variability. \emph {Right}: points coloured by class---after alignment, the two mental-state classes become linearly separable in the projected space}{figure.7}{}}
