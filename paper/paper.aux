\newlabel{fig:ablation_optimizer}{{9}{7}{QIOCE optimizer comparison. L-BFGS-B, SLSQP, COBYLA, SPSA, and NFT achieve similar AUC ($\approx 0.84$); Anderson achieves only 0.65 while consuming the most time (78~s) and evaluations (1{,}200)}{figure.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Convergence curves (mean $\pm $ std across folds) for each optimizer. Gradient-based methods (L-BFGS-B, SLSQP) converge within 50 evaluations. Anderson converges slowly and exhibits high variance, never reaching the loss achieved by other methods.}}{7}{figure.10}\protected@file@percent }
\newlabel{fig:ablation_optimizer_loss}{{10}{7}{Convergence curves (mean $\pm $ std across folds) for each optimizer. Gradient-based methods (L-BFGS-B, SLSQP) converge within 50 evaluations. Anderson converges slowly and exhibits high variance, never reaching the loss achieved by other methods}{figure.10}{}}
